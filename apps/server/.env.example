# ==============================================
# Primary Configuration
# ==============================================
CAMPUS_CART_PRIMARY__ENV=development

# ==============================================
# Server Configuration
# ==============================================
CAMPUS_CART_SERVER__PORT=8080
CAMPUS_CART_SERVER__READ_TIMEOUT=30
CAMPUS_CART_SERVER__WRITE_TIMEOUT=30
CAMPUS_CART_SERVER__IDLE_TIMEOUT=120
CAMPUS_CART_SERVER__CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# ==============================================
# Database Configuration
# ==============================================
CAMPUS_CART_DATABASE__HOST=localhost
CAMPUS_CART_DATABASE__PORT=5432
CAMPUS_CART_DATABASE__USER=postgres
CAMPUS_CART_DATABASE__PASSWORD=postgres
CAMPUS_CART_DATABASE__NAME=campuscart
CAMPUS_CART_DATABASE__SSL_MODE=disable
CAMPUS_CART_DATABASE__MAX_OPEN_CONNS=25
CAMPUS_CART_DATABASE__MAX_IDLE_CONNS=5
CAMPUS_CART_DATABASE__CONN_MAX_LIFETIME=300
CAMPUS_CART_DATABASE__CONN_MAX_IDLE_TIME=60

# ==============================================
# Redis Configuration
# ==============================================
CAMPUS_CART_REDIS__ADDRESS=localhost:6379

# ==============================================
# Integration Configuration
# ==============================================
CAMPUS_CART_INTEGRATION__RESEND_API_KEY=your_resend_api_key_here
CAMPUS_CART_INTEGRATION__SENTRY_DSN=your_sentry_dsn_here

# ==============================================
# Authentication Configuration
# ==============================================
CAMPUS_CART_AUTH_CONFIG__SECRET_KEY=your_secret_key_here_change_in_production

# ==============================================
# Observability Configuration (Optional)
# ==============================================
CAMPUS_CART_OBSERVABILITY__SERVICE_NAME=campusCart
CAMPUS_CART_OBSERVABILITY__ENVIRONMENT=development

# Logging Configuration
CAMPUS_CART_OBSERVABILITY__LOGGING__LEVEL=info
CAMPUS_CART_OBSERVABILITY__LOGGING__FORMAT=json
CAMPUS_CART_OBSERVABILITY__LOGGING__SLOW_QUERY_THRESHOLD=100ms

# New Relic Configuration
CAMPUS_CART_OBSERVABILITY__NEW_RELIC__LICENSE_KEY=
CAMPUS_CART_OBSERVABILITY__NEW_RELIC__APP_LOG_FORWARDING_ENABLED=true
CAMPUS_CART_OBSERVABILITY__NEW_RELIC__DISTRIBUTED_TRACING_ENABLED=true
CAMPUS_CART_OBSERVABILITY__NEW_RELIC__DEBUG_LOGGING=false

# Health Checks Configuration
CAMPUS_CART_OBSERVABILITY__HEALTH_CHECKS__ENABLED=true
CAMPUS_CART_OBSERVABILITY__HEALTH_CHECKS__INTERVAL=30s
CAMPUS_CART_OBSERVABILITY__HEALTH_CHECKS__TIMEOUT=5s
CAMPUS_CART_OBSERVABILITY__HEALTH_CHECKS__CHECKS=database,redis
