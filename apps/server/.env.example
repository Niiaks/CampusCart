# ==============================================
# Primary Configuration
# ==============================================
CAMPUS_CART_PRIMARY_ENV=development

# ==============================================
# Server Configuration
# ==============================================
CAMPUS_CART_SERVER_PORT=8080
CAMPUS_CART_SERVER_READ_TIMEOUT=30
CAMPUS_CART_SERVER_WRITE_TIMEOUT=30
CAMPUS_CART_SERVER_IDLE_TIMEOUT=120
CAMPUS_CART_SERVER_CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# ==============================================
# Database Configuration
# ==============================================
CAMPUS_CART_DATABASE_HOST=localhost
CAMPUS_CART_DATABASE_PORT=5432
CAMPUS_CART_DATABASE_USER=postgres
CAMPUS_CART_DATABASE_PASSWORD=postgres
CAMPUS_CART_DATABASE_NAME=campuscart
CAMPUS_CART_DATABASE_SSL_MODE=disable
CAMPUS_CART_DATABASE_MAX_OPEN_CONNS=25
CAMPUS_CART_DATABASE_MAX_IDLE_CONNS=5
CAMPUS_CART_DATABASE_CONN_MAX_LIFETIME=300
CAMPUS_CART_DATABASE_CONN_MAX_IDLE_TIME=60

# ==============================================
# Redis Configuration
# ==============================================
CAMPUS_CART_REDIS_ADDRESS=localhost:6379

# ==============================================
# Integration Configuration
# ==============================================
CAMPUS_CART_INTEGRATION_RESEND_API_KEY=your_resend_api_key_here
CAMPUS_CART_INTEGRATION_SENTRY_DSN=your_sentry_dsn_here

# ==============================================
# Authentication Configuration
# ==============================================
CAMPUS_CART_AUTH_CONFIG_SECRET_KEY=your_secret_key_here_change_in_production

# ==============================================
# Observability Configuration (Optional)
# ==============================================
CAMPUS_CART_OBSERVABILITY_SERVICE_NAME=campusCart
CAMPUS_CART_OBSERVABILITY_ENVIRONMENT=development

# Logging Configuration
CAMPUS_CART_OBSERVABILITY_LOGGING_LEVEL=info
CAMPUS_CART_OBSERVABILITY_LOGGING_FORMAT=json
CAMPUS_CART_OBSERVABILITY_LOGGING_SLOW_QUERY_THRESHOLD=100ms

# New Relic Configuration
CAMPUS_CART_OBSERVABILITY_NEW_RELIC_LICENSE_KEY=
CAMPUS_CART_OBSERVABILITY_NEW_RELIC_APP_LOG_FORWARDING_ENABLED=true
CAMPUS_CART_OBSERVABILITY_NEW_RELIC_DISTRIBUTED_TRACING_ENABLED=true
CAMPUS_CART_OBSERVABILITY_NEW_RELIC_DEBUG_LOGGING=false

# Health Checks Configuration
CAMPUS_CART_OBSERVABILITY_HEALTH_CHECKS_ENABLED=true
CAMPUS_CART_OBSERVABILITY_HEALTH_CHECKS_INTERVAL=30s
CAMPUS_CART_OBSERVABILITY_HEALTH_CHECKS_TIMEOUT=5s
CAMPUS_CART_OBSERVABILITY_HEALTH_CHECKS_CHECKS=database,redis
